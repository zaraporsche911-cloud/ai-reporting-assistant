# Copy to .env. Never commit real credentials.
POSTGRES_DB=reporting_db
POSTGRES_USER=reporting_app
POSTGRES_PASSWORD=
JWT_SECRET=
BCRYPT_STRENGTH=10
BACKEND_PORT=8090
FRONTEND_PORT=5174

# Fleet Control Tower integration: MOCK or LIVE
FLEET_API_MODE=MOCK
FLEET_API_BASE_URL=http://host.docker.internal:8080
FLEET_API_USERNAME=
FLEET_API_PASSWORD=
FLEET_API_TOKEN=

# AI provider: mock, openai, ollama, azure
AI_PROVIDER=mock
AI_MODEL=fleetops-rules-v1
AI_API_KEY=
AI_BASE_URL=https://api.openai.com
OLLAMA_BASE_URL=http://host.docker.internal:11434
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
